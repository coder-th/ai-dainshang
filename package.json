{
  "name": "ai-dianshang",
  "version": "1.0.0",
  "description": "AI E-Commerce Management System",
  "main": "electron/main.js",
  "scripts": {
    "dev": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.example.ai-dianshang",
    "productName": "AI-Dianshang",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/app.exe",
        "to": "backend/app.exe"
      }
    ],
    "win": {
      "icon": "electron/assets/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {}
  }
}
